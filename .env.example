# ============================================================
#  AI Toolkit 环境变量模板
#  复制此文件为 .env 并填写真实值
#  cp .env.example .env
# ============================================================

# ==================== 基础设施 ====================

# MySQL root 密码（必须与 infra/.env 中一致）
MYSQL_PASSWORD=root123

# MinIO 凭证（必须与 infra/.env 中一致）
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ==================== MyBatis 加解密 ====================

# 加解密密钥，16/24/32 位
# 生成工具：https://www.imaegoo.com/2020/aes-key-generator/
MYBATIS_ENCRYPTOR_PASSWORD=your-encryptor-password

# ==================== API 加密 ====================

# 请求/响应加密密钥，必须 16、24、32 位
API_ENCRYPT_REQUEST_KEY=00000000000000000000000000000000
API_ENCRYPT_RESPONSE_KEY=00000000000000000000000000000000

# ==================== AI 服务 API Key ====================

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com

# Anthropic Claude
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key

# 通义千问（DashScope）
DASHSCOPE_API_KEY=your-dashscope-api-key

# 文心一言（Qianfan）
QIANFAN_API_KEY=your-qianfan-api-key
QIANFAN_SECRET_KEY=your-qianfan-secret-key

# 智谱 AI
ZHIPUAI_API_KEY=your-zhipuai-api-key

# 字节豆包
DOUBAO_API_KEY=your-doubao-api-key

# 腾讯混元
HUNYUAN_API_KEY=your-hunyuan-api-key

# 硅基流动
SILICONFLOW_API_KEY=your-siliconflow-api-key

# 讯飞星火
XINGHUO_APP_KEY=your-xinghuo-app-key
XINGHUO_SECRET_KEY=your-xinghuo-secret-key

# 百川智能
BAICHUAN_API_KEY=your-baichuan-api-key

# Minimax
MINIMAX_API_KEY=your-minimax-api-key

# 月之暗面（KIMI）
MOONSHOT_API_KEY=your-moonshot-api-key

# Stability AI
STABILITYAI_API_KEY=your-stabilityai-api-key

# 联网搜索
WEB_SEARCH_API_KEY=your-web-search-api-key

# ==================== 第三方服务 ====================

# Midjourney
MIDJOURNEY_BASE_URL=https://api.example.com/mj
MIDJOURNEY_API_KEY=your-midjourney-api-key
MIDJOURNEY_NOTIFY_URL=http://your-domain/admin-api/ai/image/midjourney/notify

# Suno
SUNO_BASE_URL=http://127.0.0.1:3001

# 微信公众号
WX_MP_APP_ID=your-wx-mp-app-id
WX_MP_SECRET=your-wx-mp-secret

# 微信小程序
WX_MINIAPP_APPID=your-wx-miniapp-appid
WX_MINIAPP_SECRET=your-wx-miniapp-secret

# 企业微信
WX_CORP_CLIENT_ID=your-wx-corp-client-id
WX_CORP_CLIENT_SECRET=your-wx-corp-client-secret
WX_CORP_AGENT_ID=1000004

# 钉钉
DINGTALK_CLIENT_ID=your-dingtalk-client-id
DINGTALK_CLIENT_SECRET=your-dingtalk-client-secret

# QQ 地图
TENCENT_LBS_KEY=your-tencent-lbs-key

# 快递鸟
KD_NIAO_API_KEY=your-kd-niao-api-key
KD_NIAO_BUSINESS_ID=your-business-id

# 快递100
KD100_KEY=your-kd100-key
KD100_CUSTOMER=your-kd100-customer
